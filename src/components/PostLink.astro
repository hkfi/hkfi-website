---
import type { PageObjectResponse } from '@notionhq/client/build/src/api-endpoints'
import type { CardData } from '@/libs/notion/client'
import Tag from './Tag.astro'
import { localePath, DEFAULT_LOCALE } from '@/i18n/index'
import type { Locale } from '@/i18n/types'

type Props = {
  post: PageObjectResponse
  cardData?: CardData
  locale?: Locale
}

const { post, cardData, locale = DEFAULT_LOCALE } = Astro.props

const slug =
  'rich_text' in post.properties.Slug
    ? post.properties.Slug.rich_text[0].plain_text
    : ''

const title =
  'title' in post.properties.Title && post.properties.Title.title[0]
    ? post.properties.Title.title[0].plain_text
    : ''

const date =
  'date' in post.properties.Date && post.properties.Date.date
    ? post.properties.Date.date.start
    : ''

const tags =
  'Tags' in post.properties && 'multi_select' in post.properties.Tags
    ? post.properties.Tags.multi_select
    : []

const excerpt = cardData?.excerpt ?? ''
const readingTime = cardData?.readingTime ?? ''
const coverUrl = cardData?.coverUrl ?? null
const gradient =
  cardData?.gradient ??
  'linear-gradient(135deg, color-mix(in srgb, var(--color-primary) 30%, transparent) 0%, color-mix(in srgb, var(--color-secondary) 50%, transparent) 100%)'
---

<a
  transition:name={`post-link-${post.id}`}
  class='bg-secondary/20 hover:border-primary/20 group flex h-full flex-col overflow-hidden rounded-xl border border-transparent transition-all duration-300 hover:scale-[1.02] hover:shadow-xl'
  href={localePath(locale, `/blog/post/${slug}`)}
>
  <!-- Cover image or gradient -->
  <div class='relative h-32 w-full overflow-hidden'>
    {
      coverUrl ? (
        <img
          src={coverUrl}
          alt=''
          class='h-full w-full object-cover transition-transform duration-300 group-hover:scale-105'
          loading='lazy'
        />
      ) : (
        <div
          class='h-full w-full transition-opacity duration-300 group-hover:opacity-80'
          style={`background: ${gradient}`}
        />
      )
    }
  </div>

  <!-- Content -->
  <div class='flex flex-grow flex-col justify-between p-4'>
    <div>
      <div
        class='group-hover:text-primary/80 text-xl font-bold tracking-tight text-primary transition-colors'
        transition:name={`post-${post.id}`}
      >
        {title}
      </div>
      {
        excerpt && (
          <p class='text-default/50 mt-2 line-clamp-2 text-sm leading-relaxed'>
            {excerpt}
          </p>
        )
      }
    </div>

    <div class='mt-4 flex items-end justify-between'>
      <div class='flex flex-wrap gap-1.5'>
        {tags.map((tag) => <Tag tag={tag} size='sm' />)}
      </div>
      <div class='text-default/40 flex shrink-0 items-center gap-1.5 text-xs'>
        {
          readingTime && (
            <>
              <span>{readingTime}</span>
              <span>·</span>
            </>
          )
        }
        <span>{date}</span>
      </div>
    </div>
  </div>
</a>
