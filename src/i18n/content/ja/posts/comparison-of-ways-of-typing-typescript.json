    },
    {
      "id": "bd247f03-60d7-4ef5-889e-3616975b8e64",
      "type": "bulleted_list_item",
      "richText": [
        {
          "plainText": "特定の理由でTypeScriptの推論した型をオーバーライドする必要がある場合。",
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
