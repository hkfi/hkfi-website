      "id": "b1d72558-47bb-4550-900a-32eb9cefba39",
      "type": "bulleted_list_item",
      "richText": [
        {
          "plainText": "外部ソース（APIなど）からのデータを扱う際、型について確信があるがTypeScriptが推論できない場合。",
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
