      "type": "bulleted_list_item",
      "richText": [
        {
          "plainText": "型アサーションはできるだけ避けましょう。アサートする型が有効であると確信できる場合にのみ使用してください。",
          "annotations": {
            "bold": false,
            "italic": false,
