        {
          "plainText": "brew info sqlite",
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": true,
            "color": "default"
          },
          "href": null
        },
        {
          "plainText": "を実行し、caveatsの出力でパスを確認できます。",
          "annotations": {
            "bold": false,
            "italic": false,
            "strikethrough": false,
            "underline": false,
            "code": false,
